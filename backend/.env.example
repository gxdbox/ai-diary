# 阿里云百炼API
DASHSCOPE_API_KEY=your_api_key_here

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./ai_diary.db

# 向量数据库
CHROMA_PERSIST_DIR=./chroma_data

# 应用配置
APP_ENV=development
DEBUG=true

# 阿里云 OSS 对象存储（图片/音频）
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET_NAME=ai-diary-bucket
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# 阿里云 OSS 配置(用于备份存储)
OSS_BACKUP_BUCKET_NAME=ai-diary-backups
OSS_BACKUP_PATH=backups/

# Sentry 错误追踪 (可选)
SENTRY_DSN=https://2141f9cfe1340eb4361aebb2b4c6131f@o4511567747809280.ingest.us.sentry.io/4511578976223232